{
    "name": "lphenom/db",
    "description": "LPhenom database layer — raw SQL, repository pattern, PDO driver, migration contracts",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "dmitrii-pov",
            "email": "popkovd.o@yandex.ru"
        }
    ],
    "require": {
        "php": ">=8.1",
        "ext-pdo": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "phpstan/phpstan": "^1.10",
        "friendsofphp/php-cs-fixer": "^3.40",
        "ext-pdo_sqlite": "*"
    },
    "autoload": {
        "psr-4": {
            "LPhenom\\Db\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "LPhenom\\Db\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}

