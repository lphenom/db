{
    "name": "lphenom/db",
    "description": "LPhenom database layer — raw SQL, repository pattern, PDO driver, migration contracts",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "dmitrii-pov",
            "email": "popkovd.o@yandex.ru"
        }
    ],
    "require": {
        "php": ">=8.1",
        "ext-pdo": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "phpstan/phpstan": "^1.10",
        "friendsofphp/php-cs-fixer": "^3.40 <3.65"
    },
    "suggest": {
        "ext-pdo_sqlite": "Required for running unit tests with SQLite in-memory database",
        "ext-pdo_mysql": "Required for PdoMySqlConnection driver",
        "ext-ffi": "Required for FfiMySqlConnection driver (KPHP compiled mode)"
    },
    "autoload": {
        "psr-4": {
            "LPhenom\\Db\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "LPhenom\\Db\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true,
        "platform": {
            "php": "8.1.0"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}


