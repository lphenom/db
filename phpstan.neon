parameters:
    level: 8
    paths:
        - src
        - tests
    treatPhpDocTypesAsCertain: false
    ignoreErrors:
        # PHPStan cannot resolve dynamic FFI method calls (mysql_init, mysql_query, etc.)
        # These are valid at runtime when libmysqlclient is loaded via FFI::cdef().
        -
            message: '#Call to an undefined method FFI::#'
            path: src/Driver/FfiMySqlConnection.php
        -
            message: '#Call to an undefined method FFI::#'
            path: src/Driver/FfiMySqlResult.php
        # FFI::cdef() throws FFI\Exception when lib is missing.
        # On PHP 8.1 FFI\Exception extends \Exception; on PHP 8.2+ it extends \Error.
        # PHPStan may report one of the two catch blocks as "dead" depending on PHP version.
        -
            message: '#Dead catch - (Exception|Error) is never thrown in the try block#'
            path: src/Driver/FfiMySqlConnection.php
